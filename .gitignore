# Backup files
*.backup
*.bak*
*~
.DS_Store

# Logs
*.log

# Cache
cache/

# Tmux plugins (installed by tpm)
tmux/.config/tmux/plugins/

# Nvim generated/machine-local files
nvim/.config/nvim/lazy-lock.json
nvim/.config/nvim/.neoconf.json
nvim/.config/nvim/lazyvim.json
nvim/.config/nvim/plugin/*
!nvim/.config/nvim/plugin/after/
nvim/.config/nvim/plugin/after/*
!nvim/.config/nvim/plugin/after/transparency.lua
# Nvim theme symlink (machine-local, points to ~/.config/omarchy/current/theme/neovim.lua)
nvim/.config/nvim/lua/plugins/theme.lua

# Zed generated files
zed/.config/zed/.blob_store/
zed/.config/zed/copilot/
zed/.config/zed/node/
zed/.config/zed/prettier/
zed/.config/zed/db/

# NWG dock generated
nwg-dock-hyprland/.config/nwg-dock-hyprland/colors.css

# Agent files
**/.claude/
/cava/.config/cava/themes/omarchy
/superfile/.config/superfile/theme/omarchy.toml
/zed/.config/zed/themes/omarchy.json

# GitHub CLI auth (sensitive)
gh/.config/gh/hosts.yml

# Git local identity/credentials (sensitive)
git/.config/git/config.local

# Opencode generated files
opencode/.config/opencode/node_modules/
